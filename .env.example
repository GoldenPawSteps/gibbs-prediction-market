# Application
APP_BASE_URL=http://localhost:5173
# Must match the frontend origin exactly (scheme + host + port)
ALLOWED_ORIGIN=http://localhost:5173
# Allow non-browser clients without Origin/Referer headers on unsafe methods
CSRF_ALLOW_MISSING_ORIGIN=false
# Optional at-rest encryption key for users.json and marketStates.json
# Generate with: openssl rand -hex 32
# One-time migration after setting the key: npm run migrate:data-encryption
# With a key set, /api/health/data will flag migrationPending=true until both files are encrypted.
# During key rotation, set DATA_ENCRYPTION_PREVIOUS_KEY to the old key until migration completes.
DATA_ENCRYPTION_KEY=
DATA_ENCRYPTION_PREVIOUS_KEY=
# Optional backup root for npm run backup:data
DATA_BACKUP_ROOT=
# Restore from a specific backup directory with: DATA_BACKUP_PATH=/abs/path npm run restore:data
DATA_BACKUP_PATH=
JWT_SECRET=replace-with-a-strong-secret

# Login lockout (per-account brute-force protection)
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900

# SMTP email delivery
# Optional preset: custom|resend|sendgrid|postmark|mailgun
SMTP_PROVIDER=custom
REQUIRE_SMTP=false
EMAIL_FROM=noreply@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# Example preset: Resend
# SMTP_PROVIDER=resend
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=auth@your-domain.com

# Example preset: SendGrid
# SMTP_PROVIDER=sendgrid
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=auth@your-domain.com
